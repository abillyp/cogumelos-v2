# ── Banco de dados ────────────────────────────────────────────────────────────
DB_PASSWORD=troque_por_senha_forte

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=troque_por_secret_aleatorio_minimo_64_caracteres

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Crie em: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-seu-secret-aqui

# ── URLs ──────────────────────────────────────────────────────────────────────
# Desenvolvimento local
FRONTEND_URL=http://localhost:3000

# Produção (VPS)
# FRONTEND_URL=https://seudominio.com.br
